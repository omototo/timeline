{
  "name": "timeline-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "author": "The Excel Parametric Timeline contributors",
  "homepage": "https://github.com/omototo/timeline#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/omototo/timeline.git"
  },
  "bugs": {
    "url": "https://github.com/omototo/timeline/issues"
  },
  "funding": "https://buymeacoffee.com/omototo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "build": "tsc -b && bun run --filter @timeline/addin build",
    "check:text": "bun scripts/check-text.ts",
    "verify": "bun run check:text && bun run typecheck && bun run lint && bun run format:check && bun run test:cov && bun run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.30.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/eslint-plugin": "^1.3.4",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,md,yml,yaml}": "prettier --write",
    "*.{ts,tsx}": "eslint --fix"
  }
}
