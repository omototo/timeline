{
  "name": "@timeline/addin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/omototo/timeline.git",
    "directory": "packages/addin"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "certs": "office-addin-dev-certs install --days 365",
    "certs:verify": "office-addin-dev-certs verify",
    "sideload": "office-addin-debugging start manifest.xml desktop --app excel --no-debug --dev-server \"bun run dev\" --dev-server-port 9588",
    "start": "office-addin-debugging start manifest.xml desktop --app excel --dev-server \"bun run dev\" --dev-server-port 9588",
    "stop": "office-addin-debugging stop manifest.xml desktop",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@timeline/engine": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/office-js": "^1.0.592",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.6.0",
    "office-addin-debugging": "^6.1.1",
    "office-addin-dev-certs": "^2.0.9"
  }
}
